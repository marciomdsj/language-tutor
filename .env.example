# =============================================================================
# Language Tutor — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# Ollama model to use (default: qwen3:8b)
# OLLAMA_MODEL=qwen3:8b

# TTS provider: "edge" (free, default) | "openai" | "piper"
# TTS_PROVIDER=edge

# OpenAI API key (only needed if TTS_PROVIDER=openai)
# OPENAI_API_KEY=sk-...

# Deepgram API key (only needed if using Deepgram STT as fallback)
# DEEPGRAM_API_KEY=...
