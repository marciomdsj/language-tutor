# =============================================================================
# Language Tutor — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Providers (cascade: Groq → Gemini → Ollama)
# ---------------------------------------------------------------------------
# Set at least one. The system tries them in order.
# Get free keys at:
#   Groq:   https://console.groq.com/keys
#   Gemini: https://aistudio.google.com/apikey

GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=...

# Override default models (optional):
# GROQ_MODEL=groq/llama-3.3-70b-versatile
# GEMINI_MODEL=gemini/gemini-2.0-flash
# OLLAMA_MODEL=qwen3:8b

# ---------------------------------------------------------------------------
# TTS (Text-to-Speech)
# ---------------------------------------------------------------------------
# TTS_PROVIDER=edge       # "edge" (free, default) | "openai" | "piper"
# OPENAI_API_KEY=sk-...   # Only needed if TTS_PROVIDER=openai

# ---------------------------------------------------------------------------
# STT (Speech-to-Text)
# ---------------------------------------------------------------------------
# STT_PROVIDER=vosk       # "vosk" (free, default) | "deepgram"
# DEEPGRAM_API_KEY=...    # Only needed if STT_PROVIDER=deepgram
